{
  "title": "81 - Hay un río cristalino",
  "author": "Robert Lowry George Henry Day",
  "speed": 1,
  "verses": [
    [
      "1. Junto al río cristalino,",
      "En la ciudad del Señor,",
      "Nacido del trono divino,",
      "Puro y lleno de resplandor."
    ],
    [
      "2. A lo largo de las orillas de este río",
      "Los redimidos vivirán,",
      "Siempre Cristo ahí sirviendo",
      "Con total devoción."
    ],
    [
      "3.Al lado de ese hermoso río",
      "Como un cristal siempre brillando,",
      "Bueno unidos estaremos",
      "Para que nuestro Dios alabe."
    ]
  ],
  "coro": [
    "Breve iremos ver o rio,",
    "Finda a peregrinação,",
    "E louvor ao Deus eterno",
    "Nossos lábios cantarão"
  ],
