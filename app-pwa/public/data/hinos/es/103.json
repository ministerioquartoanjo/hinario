  "verses": [
    [
      "1. ¡Feliz Jerusalén, mi hogar!",
      "¡Anhelo estar en ti!",
      "Siente la calma en la gloria allí,",
      "Y disfruta de tu placer."
    ],
    [
      "2. ¡Ah! ¡Feliz hogar de amor y paz!",
      "¡Jardín como ningún otro!",
      "Tu brillo de gloria y luz,",
      "Nunca lo vio mortal."
    ],
    [
      "3. Jesús pronto regresará,",
      "Y la paz del hogar más allá",
      "Entonces él reinará en ti,",
      "Mi hogar – Jerusalén"
    ]
  ],
