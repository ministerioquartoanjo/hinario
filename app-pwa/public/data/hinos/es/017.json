    [
      "1. Altamente proclaman los cielos",
      "Tu divino Creador;",
      "Anuncia el firmamento",
      "Tus obras, oh Señor.",
      "Incesante, noche y día,",
      "Dan señales de tu poder;",
      "Sin palabras proclamando",
      "Tu gloria, Tu conocimiento."
    ],
    [
      "2. Majestuoso el sol camina",
      "¡Por los cielos, con resplandor!",
      "Exultante, en su camino,",
      "Llena el mundo de calidez.",
      "Todo el vasto universo",
      "¡Cantad a coro vuestras alabanzas!",
      "Y a nosotros nos llega una dulce enseñanza.",
      "De la Palabra del Señor."
    ]
