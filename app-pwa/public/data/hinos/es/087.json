{
  "title": "87 - Se acabó el año viejo",
  "author": "Maria da Glória Loureiro de Andrade Melodia Tradicional leta",
  "speed": 1,
  "verses": [
    [
      "1. Se acabó el año viejo;",
      "Alabamos a Jesús,",
      "Porque él nos guardó del maligno",
      "Todo el año con amor."
    ],
    [
      "2. Mantennos alejados del pecado,",
      "Nuestros pasos vienen a guiar",
      "Reanimar nuestra fuerza",
      "Y se nos viene un buen año."
    ],
    [
      "3. La verdad nos preserva;",
      "Danos tu protección;",
      "De doctrina falsa e impía",
      "Libera nuestros corazones."
    ],
    [
      "4. Cristo eterno te adoramos,",
      "Porque en la gloria del esplendor,",
      "A tu lado, para siempre",
      "Viviremos, oh Señor. Amén"
    ]
  ],
