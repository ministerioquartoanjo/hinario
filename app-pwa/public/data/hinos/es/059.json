{
  "title": "59 - Decidí seguirte",
  "author": "John Ernest Bode Henry Thomas Smart",
  "speed": 1,
  "verses": [
    [
      "1. Decidí seguirte,",
      "Jesús, hasta el final,",
      "Para ti, Señor, promesa",
      "Guíame siempre.",
      "se que soy débil",
      "Y no sé hacer el bien",
      "Pero por tu gracia",
      "Siempre ganaré."
    ],
    [
      "2. Ya has ganado el mundo,",
      "Y sus malas obras,",
      "Y reinas sobre todo,",
      "Oh Príncipe de la paz.",
      "En el cielo y aquí en la tierra",
      "Gobierna tu poder,",
      "Y por tu gracia",
      "Siempre ganaré."
    ],
    [
      "3. A todos los que te siguen,",
      "y tomar su cruz,",
      "Lo prometes contigo",
      "Vivirán, Jesús;",
      "Descansarán en gloria,",
      "Contigo, oh vencedor,",
      "Porque por tu gracia",
      "Ganarán sin miedo."
    ]
  ],
  "audioFilters": {
    "gain": 1.2,
    "bass": 0,
    "mid": -5,
    "treble": 12
  },
