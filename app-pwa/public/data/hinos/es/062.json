{
  "title": "62 - Cara a cara",
  "author": "Carrie Ellis Breck Grant Colfaxtullar",
  "speed": 1,
  "verses": [
    [
      "1. ¡Cuánto anhelo ver a Cristo!",
      "Ver Su rostro, ¡qué placer!",
      "Cuando, por fin, en el hogar eterno,",
      "¡Siempre puedo verlo!"
    ],
    [
      "2. Ya lo veo muy lejos,",
      "Veo como a través de un velo,",
      "Pero quiero verlo pronto",
      "¡Cara a cara en el cielo!"
    ],
    [
      "3. ¡Ah! Que delicia estar con Cristo,",
      "¡Donde ya no hay dolor!",
      "Libre de cualquier peligro,",
      "¡Disfrutando de su amor!"
    ],
    [
      "4. Cara a cara, que alegría",
      "Tienes que vivir así",
      "Ver la cara tan querida",
      "¡Quien murió por mí!"
    ]
  ],
  "coro": [
    "Face a face eu hei de vê-lo,",
    "Quando vier em glória em luz;",
    "Face a face lá na glória,",
    "Hei de ver meu bom Jesus!"
  ],
