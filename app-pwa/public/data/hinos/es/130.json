  "speed": 1,
  "verses": [
    [
      "1. Cuando el mal me rodea",
      "Cuando ruge la tormenta,",
      "En Jesús confiaré,",
      "Porque nunca fallará."
    ],
    [
      "2. Cuando el dolor o la angustia",
      "perturba mi corazón,",
      "Tienes que confiar,",
      "Y entregárselo todo a Jesús."
    ],
    [
      "3. Cuando me siento débil,",
      "Cuando el mundo me oprime,",
      "Y pesa mi cruz,",
      "'¡Sólo cree!' - Dice Jesús."
    ],
    [
      "4. Ya sea en la oscuridad o en la luz,",
      "Siempre cerca de Jesús,",
      "Cerrar y listo para guardar",
      "Quien sólo confía."
    ]
  ],
  "coro": [
    "O segredo do viver,",
    "O segredo do vencer,",
    "É em Cristo confiar,",
    "Pois jamais irá falhar."
  ],
