{
  "title": "131 - Oh Señor, nos regocijamos",
  "author": "Leônidas Philadelpho da Siva William Lewis Rayner McCluer",
  "speed": 1,
  "verses": [
    [
      "1. Oh Señor, nos alegramos,",
      "Aquí obedecerte,",
      "Porque tú fuiste quien envió,",
      "Recibir el bautismo.",
      "Ven ahora y bendice,",
      "¡Los que vienen a alabarte así!"
    ],
    [
      "2. Tal celebración revela,",
      "Obediencia a Ti Señor;",
      "Es una figura que recuerda,",
      "Tu poder renovador.",
      "Ven a que se una a la iglesia,",
      "¿Quién quiere que Tú, Señor, sigas?"
    ],
    [
      "3. Muerte al mundo que declaramos,",
      "Al pecado y su poder,",
      "Y contigo a nuestro lado,",
      "Por supuesto que ganaremos.",
      "Oh Señor, ven y consagra",
      "¡A los que vienen a bautizarse!"
    ],
    [
      "4. Muertos para el mundo estamos,",
      "Deseamos servirle,",
      "Vivos en Jesús queremos,",
      "Tu imagen refleja.",
      "Ven, Señor, aquí para hacer,",
      "Tu gracia en nosotros crece. Amén."
    ]
  ],
