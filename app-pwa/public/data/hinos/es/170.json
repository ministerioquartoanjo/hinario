{
  "title": "170 - Siempre alegre",
  "author": "Fanny Jane Croby Robert Lowry",
  "speed": 1,
  "verses": [
    [
      "1. Alégrate de corazón,",
      "Siempre rebosante de elogios,",
      "Por nuestro Padre celestial,",
      "Muéstranos tu amor."
    ],
    [
      "2. Tenemos protección en las peleas,",
      "Dios nos toma de la mano;",
      "Tu gracia eterna,",
      "Danos fuerza en la aflicción."
    ],
    [
      "3. Él siempre guiará a los justos,",
      "Con amor, en Su luz;",
      "Juntos serviremos a todos,",
      "Al amado y buen Jesús."
    ]
  ],
  "coro": [
    "Sempre alegre, sempre alegre,",
    "É o viver do bom cristão;",
    "Oh! que regozijo pleno,",
    "Brota-lhe da salvação!"
  ],
