  "verses": [
    [
      "1. ¡Aleluya! ¡Aleluya!",
      "Se cantan himnos de agradecimiento.",
      "Jubilosos y felices,",
      "Se cantan himnos a Jesús.",
      "Para liberarnos del pecado,",
      "Sufrió una muerte triste;",
      "Triunfando de esta muerte,",
      "El dio vida eterna"
    ],
    [
      "2. Cristo, divino Redentor",
      "Pecado aniquilado",
      "Y logró la misma bendición",
      "Para aquellos a quienes rescató.",
      "Aquí hay miles de miles",
      "Para rendirle adoración,",
      "Descubriendo en su obra",
      "Vida, luz y salvación."
    ]
  ],
