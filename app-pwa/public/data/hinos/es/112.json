  "verses": [
    [
      "1. Santo y venerable nombre",
      "Jesús es tu amado.",
      "Rey de reyes, Señor eterno,",
      "Lo aclamarás en el cielo."
    ],
    [
      "2. ¡Ah! que nombre tan precioso,",
      "Porque alegra el corazón,",
      "Siendo aceptado por Jesús,",
      "Tendrás tu perdón."
    ],
    [
      "3. Este nombre lleva siempre,",
      "Para defenderte bien.",
      "Él es un arma a tu alcance,",
      "Cuando el mal se te aparece."
    ],
    [
      "4. Lleva tu nombre contigo,",
      "De Jesús el Salvador.",
      "Este nombre da consuelo,",
      "Sea cual sea el lugar."
    ]
  ],
