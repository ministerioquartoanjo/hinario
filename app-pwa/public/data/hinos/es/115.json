      "Y por tu Hijo inmaculado,",
      "Nos ofreciste la salvación.",
      "Gloria rendimos, honor, alabanza,",
      "¡Y te adoro, Redentor!"
    ],
    [
      "3. Nos convences de pecados viles,",
      "Y de justicia, tú nos das luz,",
      "Y a la verdad nos guiamos,",
      "Oh Espíritu que nos da...",
      "Gloria rendimos, honor, alabanza,",
      "¡Y adora, oh Jesús!"
    ]
  ],
