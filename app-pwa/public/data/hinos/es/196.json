{
  "title": "196 - Vosotros, criaturas del Señor",
  "author": "Francisco de Assis",
  "speed": 1,
  "verses": [
    [
      "1. Vosotros, criaturas del Señor,",
      "¡Oh, alabad a Dios!",
      "¡Oh, alábalo! ¡Aleluya!",
      "Tú, brillante Sol dorado;",
      "¡Tú, brillante luna plateada!",
      "¡Oh, alábalo! ¡Oh, alábalo!",
      "¡Aleluya! ¡Aleluya! ¡Aleluya!"
    ],
    [
      "2. Oh tierra y cielo, honrad a Dios;",
      "¡Rezo por amor y gracias dan!",
      "¡Oh, alábalo! ¡Aleluya!",
      "Flores, levántate en la canción",
      "¡Al gran Dios de la creación!",
      "¡Oh, alábalo! ¡Oh, alábalo!",
      "¡Aleluya! ¡Aleluya! ¡Aleluya!"
    ],
    [
      "3. Vosotros, hombres sabios y buenos,",
      "¡Alabad al Señor también!",
      "¡Oh, alábalo! ¡Aleluya!",
      "Dad gloria al Hijo, gloria al Padre,",
      "¡Y saludos a todos!",
      "¡Oh, alábalo! ¡Oh, alábalo!",
      "¡Aleluya! ¡Aleluya! ¡Aleluya!"
    ]
  ],
