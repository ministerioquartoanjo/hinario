{
  "title": "20 - El amor que gana",
  "author": "Henry Maxwell Wright",
  "speed": 1,
  "verses": [
    [
      "1. ¡Amor, por amor bajaste!",
      "¡Amor, que por amor moriste!",
      "¡Oh! Cuanto dolor no sufriste,",
      "Mi corazón para conquistar,",
      "¡Y mi amor gana!"
    ],
    [
      "2. Amor, que seguiste con amor",
      "¡Yo, que sin amor, viste!",
      "¡Oh! Cuanto amor sentiste por mi,",
      "Salvador mío, mi buen Jesús,",
      "¡Sufrimiento en la cruz!"
    ],
    [
      "3. Amor, ¡me perdonas todo!",
      "Amor, que hasta bendigas",
      "¡Un acusado que le tiene cariño!",
      "¡Un acusado que le tiene cariño!",
      "Conquistada, oh Salvador, por ti,",
      "¡Sentí tu gran amor!"
    ],
    [
      "4. Amor sublime que perdura,",
      "Que en tu gracia me sostienes,",
      "¡Rodeándome de mil bienaventuranzas!",
      "Acepta ahora, oh Salvador,",
      "¡Mi humilde amor!"
    ]
  ],
