{
  "title": "181 - Tu Santo Amor, Jesús",
  "author": "Sylvaus Dryden Phelps Robert Lowry",
  "speed": 1,
  "verses": [
    [
      "1. Tu Santo Amor, Jesús,",
      "Vino a alcanzarme;",
      "Mi ser, al pie de la cruz,",
      "Quiero consagrarme.",
      "Acepta, oh Salvador,",
      "De un pecador agradecido,",
      "Homenaje de alabanza,",
      "Dado con fervor."
    ],
    [
      "2. Responde, Jesús mío,",
      "Esta petición;",
      "Tuyo y solo tuyo",
      "Es mi corazón.",
      "Tu nombre enaltece,",
      "hablaré con los demás",
      "De Tu amor incomparable;",
      "ven habilítame"
    ],
    [
      "3. Dame, Señor, más fe",
      "Y amor verdadero.",
      "Para servirte y ser",
      "Mucho más leal",
      "almas para ganar",
      "Camina siempre en la luz",
      "Y mis hermanos aman;",
      "¡Ven a habilitarme! Amén"
    ]
  ],
